<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KanGain</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark shadow-lg">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Kan<span>Gain</span></a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item">
                            <a class="nav-link text-white text-uppercase fw-bold" asp-controller="Galeria" asp-action="Index">Galeria</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">Panel Admina</a>
                            </li>
                        }

                        @if (User.IsInRole("Trener"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-info" asp-controller="Pracownik" asp-action="Index">Strefa Pracownika</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-my-passes" asp-controller="Home" asp-action="LokalizacjeMapa">
                                    Nasze Kluby
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-uppercase" asp-controller="Home" asp-action="MojePlany">Moje Plany</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-my-passes" asp-controller="Karnety" asp-action="MojeKarnety">
                                    Moje Karnety
                                </a>
                            </li>
                            <li class="nav-item">
                                <span class="nav-link text-light me-3" style="text-transform: none;">
                                    Witaj, <b class="text-white">@User.Identity.Name</b>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Konto" asp-action="Wyloguj" method="post" class="form-inline m-0">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">WYLOGUJ</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link" asp-controller="Konto" asp-action="Logowanie">Logowanie</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-gym rounded-pill px-4" asp-controller="Konto" asp-action="Rejestracja">
                                    Rejestracja
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="py-4 text-center mt-auto">
        <div class="container">
            &copy; 2026 - KanGain - 
            <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: var(--gym-primary); text-decoration: none;">Polityka Prywatności</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>