<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KanGain</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        /* Globalne zmienne dla całej aplikacji */
        :root {
            --gym-primary: #ff4500;
            --gym-primary-hover: #e63e00;
            --gym-dark: #121212;
            --gym-card-bg: #1e1e1e;
        }

        body {
            background-color: #0a0a0a; /* Ekstremalnie ciemne tło strony */
            color: #f8f9fa;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Stylizacja paska nawigacji */
        .navbar {
            background-color: var(--gym-dark) !important;
            border-bottom: 2px solid var(--gym-primary);
        }
        
        .navbar-brand {
            font-weight: 900;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: white !important;
        }
        .navbar-brand span { color: var(--gym-primary); }
        
        .nav-link {
            color: #aaaaaa !important;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: color 0.3s ease;
        }
        .nav-link:hover { color: var(--gym-primary) !important; }

        /* Globalny przycisk siłowniany */
        .btn-gym {
            background-color: var(--gym-primary);
            color: white;
            border: none;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }
        .btn-gym:hover {
            background-color: var(--gym-primary-hover);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(255, 69, 0, 0.4);
        }

        footer {
            background-color: var(--gym-dark);
            border-top: 1px solid #333;
            color: #777;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark shadow-lg">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Kan<span>Gain</span></a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                    
                    <ul class="navbar-nav flex-grow-1 ms-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Trening" asp-action="Index">Treningi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Dieta" asp-action="Index">Diety</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Kontakt" asp-action="Index">Kontakt</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Regulamin">Regulamin</a>  
                        </li>
                        
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light me-3" style="text-transform: none;">
                                    Witaj, <b class="text-white">@User.Identity.Name</b>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Konto" asp-action="Wyloguj" method="post" class="form-inline m-0">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">WYLOGUJ</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link" asp-controller="Konto" asp-action="Logowanie">Logowanie</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-gym rounded-pill px-4" asp-controller="Konto" asp-action="Rejestracja">
                                    Rejestracja
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0 flex-grow-1">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="py-4 text-center mt-auto">
        <div class="container">
            &copy; 2026 - KanGain - 
            <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: var(--gym-primary); text-decoration: none;">Polityka Prywatności</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>