@model IEnumerable<KanGainNET.Models.Lokalizacja>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<div class="map-page-container">
    <div class="side-menu">
        <h3>NASZE <span style="color: #ff4500;">KLUBY</span></h3>
        <div class="clubs-list">
            @foreach (var klub in Model)
            {
                <div class="club-card" onclick="flyToLocation(@klub.Szerokosc.ToString().Replace(",", "."), @klub.Dlugosc.ToString().Replace(",", "."))">
                    <h4>@klub.Nazwa</h4>
                    <p>@klub.Adres, @klub.Miasto</p>
                </div>
            }
        </div>
    </div>
    <div id="map"></div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        var map;
        document.addEventListener("DOMContentLoaded", function () {
        map = L.map('map', { zoomControl: false }).setView([52.2, 19.0], 6);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        L.control.zoom({ position: 'bottomright' }).addTo(map);

        const kluby = @Html.Raw(Json.Serialize(Model.Select(k => new
        {
            k.Nazwa,
            k.Adres,
            Lat = k.Szerokosc.ToString().Replace(",", "."),
            Lng = k.Dlugosc.ToString().Replace(",", ".")
        })));

        kluby.forEach(k => {
        L.marker([parseFloat(k.lat), parseFloat(k.lng)])
        .addTo(map)
        .bindPopup(`<b style="color:#ff4500">${k.nazwa}</b><br><span style="color:black">${k.adres}</span>`);
        });

        setTimeout(() => { map.invalidateSize(); }, 400);
        });

        function flyToLocation(lat, lng) {
        map.flyTo([lat, lng], 15, { duration: 1.5 });
        }
    </script>
}