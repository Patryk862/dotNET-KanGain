@model KanGainNET.Models.ViewModels.DodajPlanViewModel

<div class="container mt-5" id="kreator-glowny" data-zapisane-ids="@(Model.WybraneCwiczeniaIds != null ? string.Join(",", Model.WybraneCwiczeniaIds) : "")">
    <h2 class="text-white text-uppercase fw-bold mb-4">Nowy <span style="color: var(--gym-primary)">Plan</span></h2>

    <form asp-action="ZapiszPlan" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" id="UkrytyOpisParametrow" name="UkrytyOpisParametrow" />

        <div class="row g-4">
            <div class="col-md-7">
                <div class="card bg-dark border-secondary p-4 mb-4">
                    <label class="text-secondary small text-uppercase fw-bold mb-2">Nazwa Planu</label>
                    <input asp-for="Nazwa" class="form-control bg-dark border-secondary text-white mb-3" placeholder="np. Masa 2026">

                    <label class="text-secondary small text-uppercase fw-bold mb-2">Dla kogo</label>
                    <select asp-for="WybranyUzytkownikId" asp-items="Model.Klubowicze" class="form-select bg-dark border-secondary text-white">
                        <option value="">Wybierz klubowicza...</option>
                    </select>
                </div>

                <div class="card bg-dark border-secondary p-4">
                    <h5 class="text-white mb-3">Wybierz ćwiczenia</h5>
                    <div class="list-group">
                        @foreach (var kat in Model.WszystkieCwiczenia.GroupBy(c => c.Kategoria))
                        {
                            <div class="text-secondary fw-bold small mt-3 mb-2 text-uppercase">@kat.Key</div>
                            @foreach (var cw in kat)
                            {
                                <div class="list-group-item bg-dark border-secondary d-flex justify-content-between align-items-center">
                                    <span class="text-white">@cw.Nazwa</span>
                                    <button type="button" class="btn btn-sm btn-outline-light rounded-pill add-btn"
                                            data-id="@cw.Id" data-name="@cw.Nazwa">
                                        Dodaj
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card bg-dark border-secondary p-4 h-100">
                    <h5 class="text-white mb-3">Twój zestaw:</h5>
                    <ul id="selected-list" class="list-group mb-4">
                    </ul>
                    <button type="submit" class="btn btn-gym w-100 rounded-pill mt-auto">ZAPISZ PLAN</button>
                </div>
            </div>
        </div>
    </form>
</div>

<script id="zapisaneParametryData" type="application/json">
    @Html.Raw(string.IsNullOrEmpty((string)ViewBag.ZapisaneParametryJson) ? "{}" : ViewBag.ZapisaneParametryJson)
</script>

@section Scripts {
    <script src="~/js/stworzPlan.js" asp-append-version="true"></script>
}