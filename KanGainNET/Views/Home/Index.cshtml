@model IEnumerable<KanGainNET.Models.TypKarnetu>

@{
    ViewData["Title"] = "Strona Główna";
}

<link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />

<div class="hero-section text-center shadow-lg position-relative w-100 mb-5">
    <div class="container py-5 position-relative z-index-1">
        <h1 class="display-3 fw-bold mb-3 text-uppercase text-white">
            Przekraczaj <span id="dynamic-text" class="text-gym"></span><span class="typing-cursor">&nbsp;</span>
        </h1>
        <p class="lead mb-4 mx-auto text-secondary" style="max-width: 600px;">
            Surowy klimat, najwyższej klasy sprzęt i ludzie, którzy nie szukają wymówek. 
            Gotowy na prawdziwy trening?
        </p>
        <div class="d-flex justify-content-center gap-3 mt-4">
            @if (!User.Identity.IsAuthenticated)
            {
                <a href="#sekcja-karnetow" class="btn btn-gym btn-lg px-5 rounded-pill">Dołącz do stada</a>
                <a asp-controller="Konto" asp-action="Logowanie" class="btn btn-outline-light btn-lg px-5 rounded-pill">Zaloguj się</a>
            }
            else
            {
                <a href="#sekcja-karnetow" class="btn btn-gym btn-lg px-5 rounded-pill">Kup karnet</a>
                <a asp-controller="Grafik" asp-action="Index" class="btn btn-outline-light btn-lg px-5 rounded-pill">Grafik zajęć</a>
            }
        </div>
    </div>
</div>

<div id="sekcja-karnetow" class="py-5 my-5">
    <div class="container text-center">
        <h2 class="fw-bold text-uppercase mb-2 text-white">Wybierz Swój <span class="text-gym">Arsenał</span></h2>
        <p class="text-secondary">Wybierz plan dopasowany do Twoich potrzeb.</p>
        
        <div class="carousel-container">
            <button class="carousel-btn btn-prev" onclick="moveCarousel(-1)">&#10094;</button>
            
            @{ int i = 0; }
            @foreach (var karnet in Model)
            {
                <div class="pricing-card" data-index="@i">
                    <h4 class="fw-bold text-secondary text-uppercase">@karnet.Nazwa</h4>
                    
                    <h2 class="my-4 text-white">@karnet.Cena.ToString("0") <small class="text-muted fs-6">zł</small></h2>
                    
                    <ul class="list-unstyled text-start mb-4 text-secondary">
                        @if (karnet.CzasTrwaniaDni == 1)
                        {
                            <li>✔️ Ważność: @karnet.CzasTrwaniaDni dzień</li>
                            <li>✔️ Jednorazowy wstęp</li>
                            <li>❌ Brak zajęć grupowych</li>
                        }
                        else
                        {
                            <li>✔️ Ważność: @karnet.CzasTrwaniaDni dni</li>
                            <li><strong class="text-gym">✔️ Dostęp Open 24/7</strong></li>
                            <li>✔️ Wszystkie zajęcia grupowe</li>
                        }
                    </ul>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Karnety" asp-action="KupKarnet" asp-route-id="@karnet.Id" method="post">
                            <button type="submit" class="btn w-100 rounded-pill fw-bold dynamic-btn">
                                Kupuję @karnet.Nazwa
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Konto" asp-action="Logowanie" class="btn w-100 rounded-pill fw-bold dynamic-btn">
                            Zaloguj się, by kupić
                        </a>
                    }
                </div>
                i++;
            }

            <button class="carousel-btn btn-next" onclick="moveCarousel(1)">&#10095;</button>
        </div>
    </div>
</div>

<div class="container mb-5 pb-5 mt-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="feature-card h-100 p-4 rounded-4 shadow">
                <div class="text-gym mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" viewBox="0 0 16 16"><path d="M12.428 5.758A4.002 4.002 0 0 0 8 2a4 4 0 0 0-4.428 3.758C2.593 6.438 2 7.649 2 9c0 2.761 2.686 5 6 5s6-2.239 6-5c0-1.351-.593-2.562-1.572-3.242zM8 3a3 3 0 0 1 2.946 2.45 6.096 6.096 0 0 0-5.892 0A3 3 0 0 1 8 3z"/></svg>
                </div>
                <h5 class="fw-bold text-uppercase text-white">Czyste żelastwo</h5>
                <p class="text-secondary mb-0">Strefa wolnych ciężarów zaprojektowana z myślą o profesjonalistach.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card h-100 p-4 rounded-4 shadow">
                <div class="text-gym mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-fire" viewBox="0 0 16 16"><path d="M8 16c3.314 0 6-2 6-5.5 0-1.5-.5-2.8-1.5-3.65-1.02-.87-2.12-1.25-2.75-1.55C9.12 4.98 9 4.2 9 4c0-.5.5-1 1-1.5C9.5 2 8 0 8 0s-1.5 2-2.5 2.5C6 3 6.5 3.5 6.5 4c0 .2-.12.98-.75 1.3-1.03.52-2.23 1.25-2.75 2.2C2.25 8.2 2 9.2 2 10.5 2 14 4.686 16 8 16Zm0-1c-2.76 0-5-1.76-5-4.5 0-.96.22-1.74.55-2.2.3-.41.68-.78 1.15-1.05C5.45 6.7 6.3 6.1 6.5 5.2c.2.6.65 1.15 1.1 1.45.85.58 2.05 1.22 2.05 2.85 0 1.5-1.5 2.5-3 2.5 0-.8.5-1.5 1-2.2-.6.7-1.5 1.5-1.5 2.5 0 1.5 1.2 2.5 2.5 2.5 1.3 0 2.5-1 2.5-2.5 0-1.5-1-2.5-2-3.5 1.5 1 2.5 2.5 2.5 4.5 0 2.74-2.24 4.5-5 4.5Z"/></svg>
                </div>
                <h5 class="fw-bold text-uppercase text-white">Hardcore Cardio</h5>
                <p class="text-secondary mb-0">Najnowsze maszyny z ekranami i strefa HIIT, która spali każdą kalorię.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card h-100 p-4 rounded-4 shadow">
                <div class="text-gym mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="currentColor" class="bi bi-people-fill" viewBox="0 0 16 16"><path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7Zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216ZM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/></svg>
                </div>
                <h5 class="fw-bold text-uppercase text-white">Społeczność</h5>
                <p class="text-secondary mb-0">Trenuj z ludźmi, którzy dzielą Twoją pasję. Razem możemy więcej.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}