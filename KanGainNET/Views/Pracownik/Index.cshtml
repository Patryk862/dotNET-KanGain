@{
    ViewData["Title"] = "Panel Pracownika";
}

<div class="container mt-5 mb-5">
    <h2 class="fw-bold text-white text-uppercase mb-4">
        Panel <span style="color: var(--gym-primary)">Pracownika</span>
    </h2>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card bg-dark border-secondary shadow h-100">
                <div class="card-body text-center p-4">
                    <h5 class="text-white text-uppercase mb-3">Twój Grafik</h5>
                    <p class="text-secondary small">Sprawdź nadchodzące zajęcia grupowe, które prowadzisz.</p>
                    <a asp-controller="Pracownik" asp-action="Grafik" class="btn btn-outline-light w-100 rounded-pill">
                        Sprawdź Grafik
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-dark border-secondary shadow h-100">
                <div class="card-body text-center p-4">
                    <h5 class="text-white text-uppercase mb-3">Plany Treningowe</h5>
                    <p class="text-secondary small">Twórz i przypisuj plany treningowe dla swoich podopiecznych.</p>
                    <a asp-controller="Pracownik" asp-action="PlanyTreningowe" class="btn btn-gym w-100 rounded-pill">
                        Zarządzaj Planami
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>