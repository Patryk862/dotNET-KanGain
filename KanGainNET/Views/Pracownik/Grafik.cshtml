@model IEnumerable<KanGainNET.Models.Grafik>

@{
    ViewData["Title"] = "Twój Grafik";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-white text-uppercase m-0">
            Twój <span style="color: var(--gym-primary)">Grafik</span>
        </h2>
        <a asp-action="Index" class="btn btn-secondary rounded-pill btn-sm">Powrót do panelu</a>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-center text-secondary">
                    <p class="m-0">Nie masz zaplanowanych żadnych zajęć grupowych.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle m-0">
                        <thead>
                            <tr class="text-secondary text-uppercase fs-7 border-secondary">
                                <th class="px-4 py-3">Zajęcia</th>
                                <th class="py-3">Data</th>
                                <th class="py-3">Godzina</th>
                                <th class="py-3">Sala</th>
                                <th class="px-4 py-3 text-end">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="border-secondary">
                                    <td class="px-4 py-3 fw-bold text-white">
                                        @(item.ZajeciaGrupowe?.Nazwa ?? "Brak nazwy")
                                    </td>
                                    <td class="py-3 text-secondary">
                                        @item.DataStart.ToString("dd.MM.yyyy")
                                    </td>
                                    <td class="py-3 text-secondary">
                                        @item.DataStart.ToString("HH:mm") - @item.DataKoniec.ToString("HH:mm")
                                    </td>
                                    <td class="py-3 text-secondary">
                                        @(item.Sala?.Nazwa ?? "Nieprzypisana")
                                    </td>
                                    <td class="px-4 py-3 text-end">
                                        <a asp-controller="Pracownik" asp-action="PokazWGrafikuGlownym" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light rounded-pill">
                                            Szczegóły
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        int current = (int)ViewBag.CurrentPage;
        int total = (int)ViewBag.TotalPages;
        int start = Math.Max(1, current - 2);
        int end = Math.Min(total, current + 2);

        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" asp-action="Grafik" asp-route-page="@(current - 1)">&laquo;</a>
                </li>

                @if (start > 1)
                {
                    <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Grafik" asp-route-page="1">1</a></li>
                    @if (start > 2)
                    {
                        <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li>
                    }
                }

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link bg-dark text-white border-secondary" asp-action="Grafik" asp-route-page="@i">@i</a>
                    </li>
                }

                @if (end < total)
                {
                    @if (end < total - 1)
                    {
                        <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li>
                    }
                    <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Grafik" asp-route-page="@total">@total</a></li>
                }

                <li class="page-item @(current == total ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" asp-action="Grafik" asp-route-page="@(current + 1)">&raquo;</a>
                </li>
            </ul>
        </nav>
    }
</div>