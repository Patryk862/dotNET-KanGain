@model IEnumerable<KanGainNET.Models.Sprzet>

@{
    ViewData["Title"] = "Wyposażenie";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white text-uppercase fw-bold m-0">Stan Maszyn i Sprzętu</h2>

        <form method="get" asp-controller="AdminSprzet" asp-action="Index" class="d-flex align-items-center gap-2" style="max-width: 300px;">
            <label class="text-secondary small text-uppercase fw-bold m-0 text-nowrap">Lokalizacja:</label>
            <select name="lokalizacjaId" class="form-select bg-dark text-white border-secondary" onchange="this.form.submit()">
                @foreach (var lok in ViewBag.Lokalizacje ?? new List<KanGainNET.Models.Lokalizacja>())
                {
                    <option value="@lok.Id" selected="@(lok.Id == ViewBag.WybraneId ? "selected" : null)">@lok.Nazwa</option>
                }
            </select>
        </form>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr class="text-secondary small">
                        <th>NAZWA</th>
                        <th>STAN TECHNICZNY</th>
                        <th class="text-end" style="min-width: 250px;">USTAW STAN</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-uppercase">@item.Nazwa</td>
                            <td>
                                @{
                                    var kolor = item.StanTechniczny == "Dobry" ? "text-success" :
                                                (item.StanTechniczny == "Uszkodzony" ? "text-danger" : "text-warning");
                                }
                                <span class="@kolor fw-bold">● @item.StanTechniczny</span>
                            </td>

                            <td class="text-end">
                                <form asp-controller="AdminSprzet" asp-action="ZmienStan" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <div class="d-flex gap-2 justify-content-end">
                                        <button type="submit" name="stan" value="Dobry" class="btn btn-sm btn-outline-success px-3">OK</button>
                                        <button type="submit" name="stan" value="Wymaga serwisu" class="btn btn-sm btn-outline-warning px-3">SERWIS</button>
                                        <button type="submit" name="stan" value="Uszkodzony" class="btn btn-sm btn-outline-danger px-3">AWARIA</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        int current = (int)ViewBag.CurrentPage;
        int total = (int)ViewBag.TotalPages;
        int start = Math.Max(1, current - 2);
        int end = Math.Min(total, current + 2);

        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" asp-action="Index" 
                       asp-route-page="@(current - 1)" asp-route-lokalizacjaId="@ViewBag.WybraneId">&laquo;</a>
                </li>

                @if (start > 1) {
                    <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="1" asp-route-lokalizacjaId="@ViewBag.WybraneId">1</a></li>
                    @if (start > 2) { <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li> }
                }

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="@i" asp-route-lokalizacjaId="@ViewBag.WybraneId">@i</a>
                    </li>
                }

                @if (end < total) {
                    @if (end < total - 1) { <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li> }
                    <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="@total" asp-route-lokalizacjaId="@ViewBag.WybraneId">@total</a></li>
                }

                <li class="page-item @(current == total ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="@(current + 1)" asp-route-lokalizacjaId="@ViewBag.WybraneId">&raquo;</a>
                </li>
            </ul>
        </nav>
    }

    <div class="mt-4">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Wróć</a>
    </div>
</div>