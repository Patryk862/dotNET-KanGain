@model IEnumerable<KanGainNET.Models.Uzytkownik>

@{
    ViewData["Title"] = "Pracownicy";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white text-uppercase fw-bold m-0">Zarządzanie Kadrą i Uprawnieniami</h2>

        <form method="get" asp-controller="AdminPracownicy" asp-action="Index" class="d-flex gap-2" style="max-width: 300px;">
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control bg-dark text-white border-secondary" placeholder="Szukaj po frazie..." />
            <button type="submit" class="btn btn-gym fw-bold">Szukaj</button>
        </form>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr class="text-secondary small">
                        <th>ID UŻYTKOWNIKA</th>
                        <th>IMIĘ I NAZWISKO</th>
                        <th>ADRES EMAIL</th>
                        <th>SPECJALIZACJA</th>
                        <th>ROLA</th>
                        <th class="text-end" style="min-width: 280px;">WYBÓR ROLI</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-secondary">@item.Id</td>
                            <td class="fw-bold text-uppercase">
                                @item.Profil?.Imie @item.Profil?.Nazwisko
                            </td>
                            <td>@item.Email</td>

                            <td>
                                @if (item.RolaId == 3)
                                {
                                    <form asp-controller="AdminPracownicy" asp-action="ZmienSpecjalizacje" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="searchString" value="@ViewBag.SearchString" />
                                        <input type="hidden" name="page" value="@ViewBag.CurrentPage" />

                                        <select name="specjalizacja" class="form-select form-select-sm bg-dark text-white border-secondary" onchange="this.form.submit()" style="max-width: 160px;">
                                            @foreach (var spec in ViewBag.Specjalizacje ?? new List<string>())
                                            {
                                                <option value="@spec" selected="@(item.Specjalizacja == spec ? "selected" : null)">@spec</option>
                                            }
                                        </select>
                                    </form>
                                }
                                else
                                {
                                    <select class="form-select form-select-sm bg-dark text-muted border-secondary" disabled style="max-width: 160px; opacity: 0.5;">
                                        <option>Brak</option>
                                    </select>
                                }
                            </td>

                            <td>
                                @{
                                    var klasaRoli = item.RolaId == 3 ? "text-warning" : (item.RolaId == 1 ? "text-danger" : "text-info");
                                }
                                <span class="@klasaRoli fw-bold small text-uppercase">● @item.Rola?.Nazwa</span>
                            </td>

                            <td class="text-end">
                                <div class="d-inline-flex gap-2 align-items-center">
                                    @if (item.RolaId != 1)
                                    {
                                        <form asp-controller="AdminPracownicy" asp-action="ZmienRole" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="nowaRolaId" value="2" />
                                            <input type="hidden" name="searchString" value="@ViewBag.SearchString" />
                                            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                                            <button type="submit" class="btn btn-sm @(item.RolaId == 2 ? "btn-info text-dark fw-bold" : "btn-outline-info")" @(item.RolaId == 2 ? "disabled type=button" : "")>
                                                Użytkownik
                                            </button>
                                        </form>

                                        <form asp-controller="AdminPracownicy" asp-action="ZmienRole" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="nowaRolaId" value="3" />
                                            <input type="hidden" name="searchString" value="@ViewBag.SearchString" />
                                            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                                            <button type="submit" class="btn btn-sm @(item.RolaId == 3 ? "btn-warning text-dark fw-bold" : "btn-outline-warning")" @(item.RolaId == 3 ? "disabled type=button" : "")>
                                                Trener
                                            </button>
                                        </form>

                                        <form asp-controller="AdminPracownicy" asp-action="Usun" method="post" class="d-inline ms-2">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="searchString" value="@ViewBag.SearchString" />
                                            <input type="hidden" name="page" value="@ViewBag.CurrentPage" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Usunąć użytkownika NA ZAWSZE z bazy?')">Usuń</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-danger small fw-bold text-uppercase me-3">GŁÓWNY ADMIN</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        int current = (int)ViewBag.CurrentPage;
        int total = (int)ViewBag.TotalPages;
        int start = Math.Max(1, current - 2);
        int end = Math.Min(total, current + 2);

        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(current == 1 ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="@(current - 1)" asp-route-searchString="@ViewBag.SearchString">&laquo;</a>
                </li>

                @if (start > 1)
                {
                    <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="1" asp-route-searchString="@ViewBag.SearchString">1</a></li>
                    @if (start > 2)
                    {
                        <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li>
                    }
                }

                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == current ? "active" : "")">
                        <a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="@i" asp-route-searchString="@ViewBag.SearchString">@i</a>
                    </li>
                }

                @if (end < total)
                {
                    @if (end < total - 1)
                    {
                        <li class="page-item disabled"><span class="page-link bg-dark text-white border-secondary">...</span></li>
                    }
                    <li class="page-item"><a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="@total" asp-route-searchString="@ViewBag.SearchString">@total</a></li>
                }

                <li class="page-item @(current == total ? "disabled" : "")">
                    <a class="page-link bg-dark text-white border-secondary" asp-action="Index" asp-route-page="@(current + 1)" asp-route-searchString="@ViewBag.SearchString">&raquo;</a>
                </li>
            </ul>
        </nav>
    }

    <div class="mt-4">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Wróć</a>
    </div>
</div>