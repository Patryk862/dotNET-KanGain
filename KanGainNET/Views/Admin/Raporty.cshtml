@model IEnumerable<KanGainNET.Models.Platnosc>

@{
    ViewData["Title"] = "Raporty";
}


<div class="container mt-5 mb-5">
    <h2 class="text-white text-uppercase fw-bold mb-4">Raporty Finansowe i Płatności</h2>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card bg-black border-secondary shadow p-3 text-center">
                <span class="text-secondary small text-uppercase fw-bold">Całkowity Przychód</span>
                <h2 class="text-success fw-bold mt-2">@String.Format("{0:N2}", ViewBag.TotalRevenue) zł</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-black border-secondary shadow p-3 text-center">
                <span class="text-secondary small text-uppercase fw-bold">Aktywne Karnety</span>
                <h2 class="text-gym fw-bold mt-2">@ViewBag.ActivePasses</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-black border-secondary shadow p-3 text-center">
                <span class="text-secondary small text-uppercase fw-bold">Sprzedaż w tym miesiącu</span>
                <h2 class="text-info fw-bold mt-2">+ @ViewBag.SalesThisMonth</h2>
            </div>
        </div>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="card-header bg-black border-secondary py-3">
            <h5 class="text-white text-uppercase m-0 small fw-bold">Rejestr Wszystkich Wpłat</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr class="text-secondary small">
                        <th>DATA WPŁATY</th>
                        <th>KLUBOWICZ</th>
                        <th>ADRES EMAIL</th>
                        <th>TYP SUBSKRYPCJI</th>
                        <th class="text-end">KWOTA</th>
                        <th class="text-end">STATUS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var platnosc in Model)
                        {
                            <tr>
                                <td class="text-secondary">@platnosc.DataPlatnosci.ToString("dd.MM.yyyy HH:mm")</td>

                                <td class="fw-bold text-uppercase">
                                    @platnosc.Subskrypcja?.Uzytkownik?.Profil?.Imie @platnosc.Subskrypcja?.Uzytkownik?.Profil?.Nazwisko
                                </td>

                                <td>@platnosc.Subskrypcja?.Uzytkownik?.Email</td>

                                <td class="text-info">
                                    @(platnosc.Subskrypcja?.TypKarnetu?.Nazwa ?? "Karnet Standard")
                                </td>

                                <td class="fw-bold text-end text-success">
                                    @String.Format("{0:N2}", platnosc.Kwota) zł
                                </td>
                                <td class="text-end">
                                    <span class="badge bg-success text-dark fw-bold">OPŁACONO</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Brak zarejestrowanych płatności w bazie danych.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-light rounded-pill px-4">Wróć</a>
    </div>
</div>