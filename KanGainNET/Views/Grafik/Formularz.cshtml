@model KanGainNET.Models.ViewModels.GrafikViewModel

@{
    ViewData["Title"] = Model.CzyTylkoOdczyt ? "Szczegóły Zajęć" : (Model.Id.HasValue ? "Edycja" : "Nowa Rezerwacja");
    bool isStaff = User.IsInRole("Admin") || User.IsInRole("Pracownik");
}

<div class="container mt-5">
    <div class="card bg-dark text-white shadow-lg border-secondary mx-auto" style="max-width: 500px;">
        <div class="card-header bg-black border-secondary d-flex justify-content-between align-items-center">
            <h3 class="text-gym text-uppercase mb-0 fw-bold">@ViewData["Title"]</h3>
            @if (Model.CzyTylkoOdczyt)
            {
                <span class="badge bg-secondary">PODGLĄD</span>
            }
        </div>
        <div class="card-body p-4">
            <form asp-action="Zapisz" method="post" id="grafikForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger fw-bold"></div>
                @if (Model.Id.HasValue)
                {
                    <input type="hidden" asp-for="Id" />
                }
                <input type="hidden" asp-for="DataStart" id="HiddenDataStart" />
                <input type="hidden" asp-for="DataKoniec" id="HiddenDataKoniec" />

                <div class="mb-3">
                    <label class="small text-secondary">SALA</label>
                    <select name="SalaId" class="form-select bg-black text-white border-secondary" @(Model.CzyTylkoOdczyt ? "disabled" : "")>
                        @foreach (var s in Model.DostepneSale)
                        {
                            <!option value="@s.Id" @(s.Id == Model.SalaId ? "selected" : "")>@s.Nazwa</!option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="small text-secondary">DATA</label>
                    @if (Model.CzyTylkoOdczyt)
                    {
                        <input type="text" class="form-control" value="@Model.DataStart.ToString("dd.MM.yyyy")" readonly />
                    }
                    else
                    {

                        <input type="date" id="InputData" class="form-control bg-black text-white border-secondary" value="@Model.DataStart.ToString("yyyy-MM-dd")" required />
                    }
                </div>

                <div class="row mb-3">
                    <div class="col-6">
                        <label class="small text-secondary">START</label>
                        <select id="SelectStart" class="form-select bg-black text-white border-secondary" @(Model.CzyTylkoOdczyt ? "disabled" : "")>
                            @foreach (var g in Model.ListaGodzinDropdown)
                            {
                                <!option value="@g" @(g == Model.DataStart.ToString("HH:mm") ? "selected" : "")>@g</!option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="small text-secondary">KONIEC</label>
                        <select id="SelectKoniec" class="form-select bg-black text-white border-secondary" @(Model.CzyTylkoOdczyt ? "disabled" : "")>
                            @foreach (var g in Model.ListaGodzinDropdown)
                            {
                                <!option value="@g" @(g == Model.DataKoniec.ToString("HH:mm") ? "selected" : "")>@g</!option>
                            }
                        </select>
                    </div>
                </div>

                <div id="CzasError" class="alert alert-danger d-none small p-2">Koniec musi być po starcie! (Max 21:30)</div>

                @* Sekcja Zajęć *@
                @if (isStaff || Model.ZajeciaGrupoweId.HasValue)
                {
                    <div class="mb-3">
                        <label class="small text-secondary">ZAJĘCIA</label>
                        <select id="ZajeciaSelect" name="ZajeciaGrupoweId" class="form-select bg-black text-white border-secondary" @(Model.CzyTylkoOdczyt ? "disabled" : "")>
                            <option value="">-- Brak --</option>
                            @foreach (var zg in Model.DostepneZajecia)
                            {
                                <!option value="@zg.Id" @(zg.Id == Model.ZajeciaGrupoweId ? "selected" : "")>@zg.Nazwa</!option>
                            }
                        </select>
                    </div>
                }

                @* Sekcja Trenera *@
                @if (isStaff || Model.PracownikId.HasValue)
                {
                    <div class="mb-4">
                        <label class="small text-secondary">PROWADZĄCY TRENER</label>
                        <select id="TrenerSelect" name="PracownikId" class="form-select bg-black text-white border-secondary" @(Model.CzyTylkoOdczyt ? "disabled" : "")>
                            <option value="">-- Brak --</option>
                            @foreach (var p in Model.DostepniPracownicy)
                            {
                                var nazwaTrenera = p.Uzytkownik?.Profil != null && !string.IsNullOrEmpty(p.Uzytkownik.Profil.Imie)
                                    ? $"{p.Uzytkownik.Profil.Imie} {p.Uzytkownik.Profil.Nazwisko} ({p.Uzytkownik.Email})"
                                    : p.Uzytkownik?.Email;
                                <!option value="@p.Id" @(p.Id == Model.PracownikId ? "selected" : "")>@nazwaTrenera</!option>
                            }
                        </select>
                    </div>
                }

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" asp-route-data="@Model.DataStart.ToString("yyyy-MM-dd")" class="btn btn-outline-light rounded-pill px-4">Powrót</a>
                    @if (!Model.CzyTylkoOdczyt)
                    {
                        <div>
                            @if (Model.Id.HasValue && isStaff)
                            {
                                <button type="submit" asp-action="Usun" asp-route-id="@Model.Id" class="btn btn-outline-danger rounded-pill me-2">Usuń</button>
                            }
                            <button type="submit" class="btn btn-gym px-5 rounded-pill fw-bold" id="btnZapisz">Zapisz</button>
                        </div>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const inData = document.getElementById('InputData');
            const selS = document.getElementById('SelectStart');
            const selK = document.getElementById('SelectKoniec');
            const btn = document.getElementById('btnZapisz');
            const err = document.getElementById('CzasError');
            const zajeciaSelect = document.getElementById('ZajeciaSelect');
            const trenerSelect = document.getElementById('TrenerSelect');
            const czyOdczyt = @Model.CzyTylkoOdczyt.ToString().ToLower();

            function walidujCzas() {
                const d = inData ? inData.value : "@Model.DataStart.ToString("yyyy-MM-dd")";
                const s = selS.value, k = selK.value;

                document.getElementById('HiddenDataStart').value = `${d}T${s}`;
                document.getElementById('HiddenDataKoniec').value = `${d}T${k}`;

                if (!btn) return;

                if (s >= k) {
                    err.classList.remove('d-none');
                    selK.classList.add('is-invalid');
                    btn.disabled = true;
                } else {
                    err.classList.add('d-none');
                    selK.classList.remove('is-invalid');
                    btn.disabled = false;
                }
            }

            if (selS && !czyOdczyt) {
                selS.addEventListener('change', () => {
                    if (selS.value >= selK.value) selK.selectedIndex = selS.selectedIndex + 1;
                    walidujCzas();
                });
                selK.addEventListener('change', walidujCzas);
                if (inData) inData.addEventListener('change', walidujCzas);
            }

            if (zajeciaSelect && trenerSelect && !czyOdczyt) {
                zajeciaSelect.addEventListener('change', function () {
                    const idZajecia = this.value;
                    const obecnyTrenerId = trenerSelect.value;

                    if (!idZajecia) {
                        trenerSelect.innerHTML = '<option value="">-- Brak --</option>';
                        return;
                    }

                    trenerSelect.innerHTML = '<option value="">Ładowanie trenerów...</option>';

                    fetch(`/Grafik/PobierzTrenerowPoZajeciach?zajeciaGrupoweId=${idZajecia}`)
                        .then(res => res.json())
                        .then(data => {
                            const maObecnego = data.some(t => t.id == obecnyTrenerId);
                            const zaznaczId = maObecnego ? obecnyTrenerId : (data[0]?.id || '');

                            trenerSelect.innerHTML = '<option value="">-- Brak --</option>' +
                                data.map(t => `<option value="${t.id}" ${t.id == zaznaczId ? 'selected' : ''}>${t.text}</option>`).join('');
                        })
                        .catch(() => {
                            trenerSelect.innerHTML = '<option value="">Błąd ładowania danych</option>';
                        });
                });
            }

            walidujCzas();
        });
    </script>
}